{
  "name": "campus-one-frontend",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -ws --if-present",
    "contracts:sync": "node scripts/sync-contracts.mjs",
    "contracts:check": "node scripts/sync-contracts.mjs --check",
    "supabase:check": "node scripts/check-web-school-supabase.mjs",
    "test:node": "node --test --test-isolation=none --import sucrase/register/ts.js scripts/check-web-school-supabase.test.mjs packages/api-client/src/index.test.ts apps/web-lms/lib/platform-auth.test.ts apps/web-school/src/services/backend-session.service.test.ts apps/web-school/src/services/route-access.service.test.ts",
    "verify": "npm run contracts:check && npm run supabase:check && npm run test:node && npm run build",
    "dev:web-lms": "npm --workspace apps/web-lms run dev",
    "dev:web-school": "npm --workspace apps/web-school run dev"
  }
}
